      "description": "Basic endpoints mapped from OrderController methods (show/store/update).",
      "item": [
        {
          "name": "List My Orders",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/orders?limit=5",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "orders"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "5",
                  "description": "optional | Giới hạn số đơn (1–100). Bỏ query để lấy toàn bộ."
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('List orders status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var res = pm.response.json();",
                  "pm.test('Response has common wrapper', function () {",
                  "    pm.expect(res).to.have.property('success', true);",
                  "    pm.expect(res).to.have.property('message');",
                  "    pm.expect(res).to.have.property('data');",
                  "});",
                  "",
                  "pm.test('Contains orders array', function () {",
                  "    pm.expect(res.data).to.have.property('orders');",
                  "    pm.expect(res.data.orders).to.be.an('array');",
                  "});",
                  "",
                  "if (res.data.orders && res.data.orders.length) {",
                  "    pm.test('Order row has Vietnamese status label', function () {",
                  "        var o = res.data.orders[0];",
                  "        pm.expect(o).to.have.property('order_label_status');",
                  "        pm.expect(o.order_label_status).to.be.a('string');",
                  "        pm.expect(o).to.have.property('products');",
                  "        pm.expect(o.products).to.be.an('array');",
                  "        if (o.products.length > 0) {",
                  "            pm.expect(o.products[0]).to.have.property('image_path');",
                  "        }",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Order Statuses",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/orders/statuses",
              "host": [
