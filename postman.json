{
  "info": {
    "_postman_id": "d7edfa50-d1a6-45b5-93cf-8d2441fb9f43",
    "name": "feco_api - Auth & Order Basic",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Basic Postman collection for Auth and Order APIs with token automation.\n\nWrong HTTP method or unknown paths under `/api/*` return HTTP 404 with JSON: success=false, message from `api.errors.not_found`, data object (e.g. GET on POST-only routes)."
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "login",
      "value": "admin@example.com"
    },
    {
      "key": "password",
      "value": "secret"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "order_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "login",
                  "value": "{{login}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Login via phone/email and save Sanctum token. POST only; GET (or other methods) on this URL returns 404 with the standard API error envelope."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var res = pm.response.json();",
                  "pm.test('Response has common wrapper', function () {",
                  "    pm.expect(res).to.have.property('success', true);",
                  "    pm.expect(res).to.have.property('message');",
                  "    pm.expect(res).to.have.property('data');",
                  "});",
                  "",
                  "var token = res && res.data ? res.data.token : null;",
                  "",
                  "pm.test('Token exists', function () {",
                  "    pm.expect(token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('Login includes agent info fields', function () {",
                  "    pm.expect(res.data).to.have.property('agent');",
                  "    if (res.data.agent) {",
                  "        pm.expect(res.data.agent).to.have.property('business_name');",
                  "        pm.expect(res.data.agent).to.have.property('full_address');",
                  "        pm.expect(res.data.agent).to.have.property('status');",
                  "        pm.expect(res.data.agent).to.have.property('agent_type');",
                  "        pm.expect(res.data.agent).to.have.property('agent_commission_policy');",
                  "    }",
                  "});",
                  "",
                  "if (token) {",
                  "    pm.collectionVariables.set('token', token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "logout"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Logout status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var res = pm.response.json();",
                  "pm.test('Response has common wrapper', function () {",
                  "    pm.expect(res).to.have.property('success', true);",
                  "    pm.expect(res).to.have.property('message');",
                  "    pm.expect(res).to.have.property('data');",
                  "});",
                  "",
                  "pm.collectionVariables.unset('token');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Order",
      "auth": {
