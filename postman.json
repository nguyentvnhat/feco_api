                  "pm.test('Response contains statuses array', function () {",
                  "    pm.expect(res.data).to.have.property('statuses');",
                  "    pm.expect(res.data.statuses).to.be.an('array');",
                  "});",
                  "",
                  "if (Array.isArray(res.data.statuses) && res.data.statuses.length > 0) {",
                  "    pm.test('Status item has value and label', function () {",
                  "        pm.expect(res.data.statuses[0]).to.have.property('value');",
                  "        pm.expect(res.data.statuses[0]).to.have.property('label');",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        },
