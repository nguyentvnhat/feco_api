                  "    if (res.data.agent) {",
                  "        pm.expect(res.data.agent).to.have.property('month_revenue');",
                  "        pm.expect(res.data.agent).to.have.property('month_commission');",
                  "        pm.expect(res.data.agent).to.have.property('has_agent_children');",
                  "        pm.expect(res.data.agent.month_revenue).to.be.a('string');",
                  "        pm.expect(res.data.agent.month_commission).to.be.a('string');",
                  "        pm.expect(res.data.agent.has_agent_children).to.be.a('boolean');",
                  "    }",
                  "});",
                  "",
                  "if (res.data.agent && res.data.agent.agent_commission_policy.length > 0) {",
                  "    pm.test('Commission policy item has policy info', function () {",
                  "        var p = res.data.agent.agent_commission_policy[0];",
