          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Show order status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var res = pm.response.json();",
                  "pm.test('Response has order_label_status', function () {",
                  "    pm.expect(res.data).to.have.property('order_label_status');",
