        {
          "name": "Order History Commission",
          "request": {
            "method": "GET",
            "description": "Hoa hồng của đại lý đang đăng nhập (commission_entries theo beneficiary_user_id, loại trừ entry_type=discount). Query: month (YYYY-MM), all=1 để xem tất cả tháng, status (pending|approved|paid|rejected), limit (mặc định 20).",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/order/history-commission?month=&all=&status=&limit=20",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "order",
                "history-commission"
              ],
              "query": [
                {
                  "key": "month",
                  "value": "",
                  "description": "optional | YYYY-MM (mặc định tháng hiện tại)"
                },
                {
                  "key": "all",
                  "value": "",
                  "description": "optional | 1/true để bỏ lọc tháng và xem tất cả"
                },
                {
                  "key": "status",
                  "value": "",
                  "description": "optional | pending | approved | paid | rejected"
                },
                {
                  "key": "limit",
                  "value": "20",
                  "description": "optional | 1–100, mặc định 20"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('History commission status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var res = pm.response.json();",
                  "pm.test('Hoa hồng của đại lý đang đăng nhập — has summary', function () {",
                  "    pm.expect(res).to.have.property('success', true);",
                  "    pm.expect(res.data).to.have.property('summary');",
                  "    pm.expect(res.data.summary).to.have.property('total_commission');",
                  "    pm.expect(res.data.summary).to.have.property('entry_count');",
                  "});",
                  "",
                  "pm.test('Response has entries array', function () {",
                  "    pm.expect(res.data).to.have.property('entries');",
