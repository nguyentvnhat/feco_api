        {
          "name": "Store Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "order_date",
                  "value": "2026-04-16",
                  "type": "text",
                  "description": "required | Ngay dat don, dinh dang YYYY-MM-DD"
                },
                {
                  "key": "seller_user_id",
                  "value": "1",
                  "type": "text",
                  "description": "required | ID user ban hang (exists: users.id)"
                },
                {
                  "key": "agent_profile_id",
                  "value": "",
                  "type": "text",
                  "description": "optional | ID ho so dai ly (exists: agent_profiles.id)"
                },
                {
                  "key": "order_channel",
                  "value": "agent_order",
                  "type": "text",
                  "description": "required | agent_order | direct_sale | internal_sale"
                },
                {
                  "key": "order_status",
                  "value": "new",
                  "type": "text",
                  "description": "required | Trang thai don hang (vd: new, processing, delivered...)"
                },
                {
                  "key": "customer_name",
                  "value": "Nguyen Van A",
                  "type": "text",
                  "description": "required | Ten khach hang"
                },
                {
                  "key": "customer_phone",
                  "value": "0900000000",
                  "type": "text",
                  "description": "required | So dien thoai khach hang"
                },
                {
                  "key": "customer_address",
                  "value": "123 Duong ABC",
                  "type": "text",
